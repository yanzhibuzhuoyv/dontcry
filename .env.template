# RAG System config — copy to .env and edit
# LLM (required)
RAG_LLM_API_KEY=sk-your-key-here
RAG_LLM_MODEL=deepseek-chat
RAG_LLM_BASE_URL=https://api.deepseek.com/v1

# Embedding (local by default, no API key needed)
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Optional: switch to API embedding (e.g., SiliconFlow)
# RAG_EMBEDDING_PROVIDER=api
# RAG_EMBEDDING_MODEL=BAAI/bge-m3
# RAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# RAG_EMBEDDING_API_KEY=your-siliconflow-key

# RAG settings
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_VECTOR_STORE_DIR=./rag_index
